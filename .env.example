# Copy to .env and edit before `docker compose up`.

# REQUIRED — share with Trailbox clients via the "허브 설정" dialog.
# Generate a fresh one:  python -c "import secrets; print(secrets.token_urlsafe(32))"
TRAILBOX_HUB_TOKEN=changeme-generate-a-real-token

# Days to keep uploaded sessions before auto-deletion. 0 = forever.
TRAILBOX_HUB_RETENTION_DAYS=0

# Cap on a single session upload (MB).
TRAILBOX_HUB_MAX_UPLOAD_MB=8192

# Only needed if you uncomment the caddy service for public TLS.
# TRAILBOX_HUB_DOMAIN=hub.example.com
